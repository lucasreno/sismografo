{
  "name": "sismografo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monitora aplicações web executando fluxos gravados, aprende o normal e registra anomalias como um livro de sintomas e diagnósticos.",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^11.8.0",
    "fastify": "^5.2.0",
    "playwright": "^1.50.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
